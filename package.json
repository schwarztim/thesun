{
  "name": "thesun",
  "version": "0.1.0",
  "description": "Autonomous MCP server generation and orchestration platform",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "thesun": "./dist/cli/index.js",
    "thesun-mcp": "./dist/mcp-server/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "mcp": "node dist/mcp-server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "generate": "node dist/cli/index.js generate",
    "orchestrator:start": "node dist/orchestrator/index.js",
    "orchestrator:status": "node dist/cli/index.js status"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^11.7.2",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "openapi-types": "^12.1.3",
    "ora": "^8.0.0",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^9.26.0",
    "nock": "^14.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.32.0",
    "vitest": "^4.0.17"
  },
  "overrides": {
    "hono": "^4.11.7"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
