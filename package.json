{
  "name": "thesun",
  "version": "0.1.0",
  "description": "Autonomous MCP server generation and orchestration platform",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "thesun": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "generate": "node dist/cli/index.js generate",
    "orchestrator:start": "node dist/orchestrator/index.js",
    "orchestrator:status": "node dist/cli/index.js status"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.24.1",
    "winston": "^3.17.0",
    "axios": "^1.7.9",
    "glob": "^11.0.0",
    "@apidevtools/json-schema-ref-parser": "^11.7.2",
    "openapi-types": "^12.1.3",
    "better-sqlite3": "^11.7.0",
    "commander": "^12.1.0",
    "ora": "^8.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "typescript": "^5.7.2",
    "vitest": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.17",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "prettier": "^3.2.0",
    "nock": "^14.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
